---
import MainLayout from '../layouts/MainLayout.astro';
import CinematicStory from '../components/CinematicStory';

import VerticalProcess from '../components/VerticalProcess';
import ProductGrid from '../components/ProductGrid';
import ArchitecturalSection from '../components/ArchitecturalSection.jsx';
import CTA from '../components/CTA';

import { getExclusivas, getColeccion } from '../lib/products';

// "Categorías Exclusivas" — 3 curated products, max visual diversity, sorted by priority
const GRID_PRODUCTS = getExclusivas().map((p) => ({
  ...p,
  description: p.tags.join(' · '),
  tag: p.tags[0] ?? null,
}));

// "Selección de Temporada" — curated colección, zero overlap with exclusivas
const FEATURED_PRODUCTS = getColeccion().map((p) => ({
  ...p,
  tastingNotes: p.tags.join(', '),
  price: null,
  tag: p.tags[0] ?? null,
  category: 'Café Coocentral',
}));
---

<!--
  Orden de la home: la historia se cuenta COMPLETA dentro del bloque
  cinemático de apertura (personas antes que el café, pilar 1 del brief),
  y la tienda entra inmediatamente después para no alejar la compra.
  Las secciones siguientes profundizan, no repiten.
-->
<MainLayout title="Café Coocentral | Cada taza cuenta una historia que transforma vidas">
	{/* 1 — La apertura completa, una sola animación continua:
	       granos → logo → finca → oportunidades → tierra (scrub) */}
	<CinematicStory client:load />

	{/* 2 — La tienda, sin hacer esperar al cliente */}
	<ProductGrid
		client:visible
		products={GRID_PRODUCTS}
		limit={3}
		eyebrow="NUESTROS CAFÉS"
		heading="Y este es el café"
		headingItalic="que nace de ahí."
		description="Viene de las mismas montañas y de las mismas familias que acabas de conocer."
	/>

	{/* 3 — Cómo se hace: el viaje horizontal del proceso. Va justo después
	       del primer café para que la prueba llegue apenas nace el interés.
	       El recorrido NO se corta: su último tramo desemboca —con el mismo
	       hilo conductor— en las ediciones ("Cafés con nombre y con historia"),
	       que entran como panel final del viaje antes de soltar el scroll. */}
	<VerticalProcess client:load editions={FEATURED_PRODUCTS} />

	{/* 4 — Profundidad: las raíces y las familias */}
	<ArchitecturalSection client:visible />

	{/* 5 — El cierre: el manifiesto de marca ("Haz parte"). La exportación
	       (B2B) vive en su propia página /exportacion para no repetir aquí
	       el mismo mensaje de "familias / al mundo". */}
	<CTA client:visible />
</MainLayout>
