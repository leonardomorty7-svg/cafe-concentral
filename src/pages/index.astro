---
import MainLayout from '../layouts/MainLayout.astro';
import IntroAnimation from '../components/IntroAnimation';
import Hero from '../components/Hero';

import ProcessSection from '../components/ProcessSection';
import ExperienceSection from '../components/ExperienceSection.jsx';
import ProductGrid from '../components/ProductGrid';
import ExportSection from '../components/ExportSection';
import FeaturedProducts from '../components/FeaturedProducts';
import ProductSlider from '../components/ProductSlider';
import ArchitecturalSection from '../components/ArchitecturalSection.jsx';
import CTA from '../components/CTA';

import { getExclusivas, getColeccion } from '../lib/products';

// "Categorías Exclusivas" — 3 curated products, max visual diversity, sorted by priority
const GRID_PRODUCTS = getExclusivas().map((p) => ({
  ...p,
  description: p.tags.join(' · '),
  tag: p.tags[0] ?? null,
}));

// "Selección de Temporada" — curated colección, zero overlap with exclusivas
const FEATURED_PRODUCTS = getColeccion().map((p) => ({
  ...p,
  tastingNotes: p.tags.join(', '),
  price: null,
  tag: p.tags[0] ?? null,
  category: 'Café Concentral',
}));
---

<MainLayout title="Café Concentral | El Alma de Colombia">
	<IntroAnimation client:only="react" />
	<Hero client:load />
	
	<section id="about" class="section-container text-center">
		<span class="label-premium mx-auto reveal">Nuestra Esencia</span>
		<h2 class="text-4xl md:text-6xl mb-10 reveal delay-100">Pasión por el origen, <br /><span class="italic-serif text-accent-gold">rigor en el detalle.</span></h2>
		<p class="text-base-muted max-w-3xl mx-auto leading-[1.7] text-lg font-light reveal delay-200">
			Café Concentral nació de la necesidad de reconectar al consumidor final con la tierra. No solo vendemos café; entregamos el resultado de generaciones de conocimiento cafetero, procesado bajo los más altos estándares tecnológicos y humanos.
		</p>
	</section>

	<ProcessSection client:visible />
	
	<ExperienceSection client:visible />

	<ProductGrid client:visible products={GRID_PRODUCTS} limit={3} />
	
	<ExportSection client:visible />

	<ProductSlider client:visible products={FEATURED_PRODUCTS} />
	
	<ArchitecturalSection client:visible />
	
	<CTA client:visible />
</MainLayout>
