---
import MainLayout from '../layouts/MainLayout.astro';
import ProductGrid from '../components/ProductGrid';
import { getAllProducts } from '../lib/products';

const GRID_PRODUCTS = getAllProducts().map((p) => ({
  ...p,
  description: p.tags.join(' · '),
  tag: p.tags[0] ?? null,
}));
---

<MainLayout title="Productos | Café Concentral">
	<div class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
		<h1 class="text-5xl font-bold mb-8">Nuestros Productos</h1>
		<p class="text-neutral-500 text-lg max-w-3xl">Catálogo completo de café en grano, molido y especialidades. Próximamente.</p>
	</div>
	
	<ProductGrid client:load products={GRID_PRODUCTS} />
</MainLayout>
