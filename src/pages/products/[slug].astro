---
/**
 * /src/pages/products/[slug].astro
 *
 * Dynamic Product Detail Page.
 * - Routes are pre-generated at build time via getStaticPaths()
 * - Slug matches product.id from products.js
 * - All data comes from the existing product catalogue — no invented content
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getAllProducts } from '../../lib/products';
import ProductGallery from '../../components/ProductGallery.jsx';
import ProductGrid from '../../components/ProductGrid.jsx';
import AddToCart from '../../components/AddToCart.jsx';

export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

// Safety guard — getStaticPaths ensures this never fires in production,
// but keeps local dev and edge cases safe.
if (!product) {
  return Astro.redirect('/productos');
}

const {
  name,
  id,
  category,
  subcategory,
  tags = [],
  image,
  images = [],
} = product;

// Human-readable category label
const categoryLabel =
  category === 'cafe' ? 'Café' :
  category === 'accesorios' ? 'Accesorios' :
  category === 'experiencias' ? 'Experiencias' :
  category === 'alimentos' ? 'Alimentos' :
  category;

// Use all available images; fall back to the primary image
const gallery = images.length > 1 ? images : [image];

// Primary tag used as the "badge"
const badge = tags[0] ?? null;

// Remaining tags used as sensory / descriptive chips
const chips = tags.slice(1);

// Intro editorial por categoría, en la voz del brief
const categoryIntro =
  category === 'cafe'
    ? 'Cultivado por familias de nuestra cooperativa en las montañas del Huila, y tostado para que cada sorbo cuente de dónde viene.'
    : category === 'alimentos'
      ? 'Tradición del Huila hecha en casa: el acompañante de siempre para nuestro café.'
      : 'Seleccionado por nosotros para preparar nuestro café en casa como se merece.';

// Relacionados: primero de la misma categoría, luego el resto — nunca el actual
const allProducts = getAllProducts();
const related = [
  ...allProducts.filter((p) => p.category === category && p.id !== id),
  ...allProducts.filter((p) => p.category !== category && p.id !== id),
]
  .slice(0, 3)
  .map((p) => ({ ...p, description: p.tags.join(' · '), tag: p.tags[0] ?? null }));
---

<MainLayout
  title={`${name} | Café Coocentral`}
  description={`Descubre ${name} — ${tags.join(', ')}. Parte de la colección ${categoryLabel} de Café Coocentral.`}
>
  <!-- Ensure page always starts at top -->
  <script>window.scrollTo(0, 0);</script>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="min-h-screen bg-[#F5F1EB] pt-28 pb-20">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] text-[#D1AA49] font-bold mb-14" aria-label="Breadcrumb" data-fx="rise">
        <a href="/" class="hover:text-[#1A1A1A] transition-colors duration-300">Inicio</a>
        <span class="text-[#D6D1C9]">—</span>
        <a href="/productos" class="hover:text-[#1A1A1A] transition-colors duration-300">Productos</a>
        <span class="text-[#D6D1C9]">—</span>
        <span class="text-[#1A1A1A]/50">{name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 xl:gap-24 items-start">

        <!-- LEFT — Interactive image gallery -->
        <div data-fx="rise">
          <ProductGallery
            client:load
            images={gallery}
            name={name}
            badge={badge}
          />
        </div>

        <!-- RIGHT — Product info -->
        <div class="flex flex-col" data-fx="header">

          <!-- Category eyebrow -->
          <span class="text-[10px] uppercase tracking-[0.4em] text-[#D1AA49] font-bold mb-4 block" data-fx-eyebrow>
            {categoryLabel} <span class="mx-2 text-[#D6D1C9]">/</span> {subcategory}
          </span>

          <!-- Product name -->
          <h1 class="font-serif text-5xl md:text-6xl xl:text-7xl text-[#1A1A1A] leading-[1.05] tracking-[-0.03em] mb-10">
            {name}
          </h1>

          <!-- Tags / sensory chips -->
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-10" data-fx="rise">
              {tags.map((tag) => (
                <span class="text-[10px] uppercase tracking-[0.18em] font-bold text-[#1A1A1A] bg-white border border-[#1A1A1A]/8 px-4 py-2 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Divider -->
          <div class="w-12 h-px bg-[#D1AA49] mb-10"></div>

          <!-- Category description — editorially tailored per category -->
          <p class="text-[#6B6B6B] font-light text-lg leading-[1.8] mb-14 max-w-md">
            {categoryIntro}
          </p>

          <!-- Compra — carrito + WhatsApp directo -->
          <div data-fx="rise">
            <AddToCart client:load id={id} name={name} image={image} />
            <a
              href="/productos"
              class="inline-flex items-center gap-2 mt-8 text-[11px] font-bold uppercase tracking-[0.2em] text-[#1A1A1A] border-b border-[#1A1A1A]/20 pb-1 hover:border-[#D1AA49] hover:text-[#D1AA49] transition-all"
            >
              Explorar toda la colección
              <span aria-hidden="true">→</span>
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── SENSORY PROFILE ──────────────────────────────────────────────── -->
  {tags.length > 0 && (
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

          <div data-fx="header">
            <span class="label-premium">Perfil Sensorial</span>
            <h2 class="font-serif text-3xl md:text-4xl text-[#1A1A1A] leading-tight mb-8">
              Notas y <span class="italic text-[#D1AA49]">carácter.</span>
            </h2>
            <p class="text-[#6B6B6B] font-light leading-relaxed">
              Cada café nuestro sale de un lote real, cultivado y seleccionado por familias de nuestra cooperativa. Estas notas son su identidad.
            </p>
          </div>

          <!-- Chips grid -->
          <div class="flex flex-wrap gap-3" data-fx="stagger">
            {tags.map((note, i) => (
              <div class="group flex items-center gap-3 bg-[#F5F1EB] rounded-sm px-5 py-4 transition-all duration-300 hover:bg-[#D1AA49]/10">
                <span class="text-[#D1AA49] font-serif text-lg font-medium">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-[11px] uppercase tracking-[0.2em] font-bold text-[#1A1A1A]">{note}</span>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>
  )}

  <!-- ─── ORIGIN / CATEGORY DETAIL ────────────────────────────────────── -->
  <section class="py-24 bg-[#F5F1EB]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <div data-fx="header">
          <span class="label-premium">
            {category === 'cafe' ? 'Origen & Proceso' : 'Detalles del Producto'}
          </span>
          <h2 class="font-serif text-3xl md:text-4xl text-[#1A1A1A] leading-tight mb-12">
            Lo que hace <span class="italic text-[#D1AA49]">especial</span> a esta selección.
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8" data-fx="stagger">
          <!-- Categoría -->
          <div class="border-t border-[#1A1A1A]/8 pt-6">
            <p class="text-[10px] uppercase tracking-[0.25em] text-[#D1AA49] font-bold mb-2">Categoría</p>
            <p class="font-serif text-lg text-[#1A1A1A]">{categoryLabel}</p>
          </div>

          <!-- Tipo -->
          <div class="border-t border-[#1A1A1A]/8 pt-6">
            <p class="text-[10px] uppercase tracking-[0.25em] text-[#D1AA49] font-bold mb-2">Tipo</p>
            <p class="font-serif text-lg text-[#1A1A1A] capitalize">{subcategory.replace(/-/g, ' ')}</p>
          </div>

          <!-- Tags restantes como pares clave-valor -->
          {tags.map((tag) => (
            <div class="border-t border-[#1A1A1A]/8 pt-6">
              <p class="text-[10px] uppercase tracking-[0.25em] text-[#D1AA49] font-bold mb-2">Perfil</p>
              <p class="font-serif text-lg text-[#1A1A1A]">{tag}</p>
            </div>
          ))}

          <!-- País de origen -->
          <div class="border-t border-[#1A1A1A]/8 pt-6">
            <p class="text-[10px] uppercase tracking-[0.25em] text-[#D1AA49] font-bold mb-2">Origen</p>
            <p class="font-serif text-lg text-[#1A1A1A]">Colombia</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BRAND STORY ──────────────────────────────────────────────────── -->
  <section class="py-24 bg-[#1A1A1A]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <div data-fx="header">
          <span class="text-[11px] uppercase tracking-[0.3em] text-[#D1AA49] font-bold mb-6 block" data-fx-eyebrow>
            Nuestra Promesa
          </span>
          <h2 class="font-serif text-3xl md:text-5xl text-white leading-tight mb-8">
            Cultivado con <span class="italic text-[#D1AA49]">propósito.</span>
          </h2>
          <p class="text-white/60 font-light text-base leading-relaxed mb-6">
            Café Coocentral no nació solo para producir café: nació para crear oportunidades. Cada selección reúne el trabajo de miles de familias del Huila que creen en la cooperación y en el valor de su tierra.
          </p>
          <p class="text-white/60 font-light text-base leading-relaxed">
            <strong class="text-white font-medium">{name}</strong> es parte de esa historia — cultivado, procesado y compartido con el mismo cuidado que ponemos en cada lote que sale de nuestras montañas.
          </p>
        </div>

        <!-- Visual accent -->
        <div class="relative aspect-square rounded-sm overflow-hidden opacity-80" data-fx="parallax">
          <img
            src={image}
            alt={`${name} — Café Coocentral`}
            class="w-full h-full object-cover grayscale contrast-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/70 to-transparent"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── RELACIONADOS — que la ficha nunca sea un callejón sin salida ── -->
  {related.length > 0 && (
    <ProductGrid
      client:visible
      products={related}
      limit={3}
      eyebrow="SIGUE EXPLORANDO"
      heading="También de"
      headingItalic="nuestra cooperativa."
      description="Otros frutos de las mismas montañas y de las mismas manos."
    />
  )}

  <!-- ─── SECONDARY CTA ────────────────────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 text-center" data-fx="header">
      <span class="label-premium mx-auto">¿Te interesa esta selección?</span>
      <h2 class="font-serif text-3xl md:text-5xl text-[#1A1A1A] leading-tight mb-6 mx-auto">
        Hablemos sobre <span class="italic text-[#D1AA49]">tu pedido.</span>
      </h2>
      <p class="text-[#6B6B6B] font-light leading-relaxed mb-12 mx-auto">
        Detrás de este botón hay alguien de nuestra cooperativa, listo para ayudarte con tu selección o tu pedido.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-fx="rise">
        <a href="/contacto" class="btn-primary">
          Hablar con nosotros
        </a>
        <a href="/productos" class="btn-secondary">
          Ver más productos
        </a>
      </div>
    </div>
  </section>

</MainLayout>
