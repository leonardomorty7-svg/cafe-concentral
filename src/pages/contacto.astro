---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm';
---

<MainLayout 
  title="Contacto | Café Concentral"
  description="Contacta con nuestro equipo de expertos. Solicitudes B2B, exportación y pedidos especiales."
>
  <!-- Hero Section -->
  <section class="pt-48 pb-24 bg-[#0B0B0B] text-white">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <span class="label-premium mx-auto">Conversaciones con Propósito</span>
      <h1 class="font-serif text-5xl md:text-7xl mb-8 leading-tight">
        Hablemos sobre <span class="italic text-accent-gold">tu café.</span>
      </h1>
      <p class="text-white/60 text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed">
        Ya sea para una consulta de exportación, una alianza B2B o simplemente para saber más sobre nuestro origen, estamos aquí para escucharte.
      </p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-24 bg-[#F5F1EB] relative -mt-12 z-10">
    <div class="max-w-4xl mx-auto px-6">
      <ContactForm client:load />
    </div>
  </section>

  <!-- Info Grid -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 text-center">
        <div>
          <span class="text-accent-gold text-sm font-bold uppercase tracking-widest block mb-4">Exportación</span>
          <p class="font-serif text-xl text-base-black">export@cafeconcentral.com</p>
        </div>
        <div>
          <span class="text-accent-gold text-sm font-bold uppercase tracking-widest block mb-4">Ventas Locales</span>
          <p class="font-serif text-xl text-base-black">+57 300 000 0000</p>
        </div>
        <div>
          <span class="text-accent-gold text-sm font-bold uppercase tracking-widest block mb-4">Prensa</span>
          <p class="font-serif text-xl text-base-black">media@cafeconcentral.com</p>
        </div>
      </div>
    </div>
  </section>

</MainLayout>
