---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Exportación | Café Coocentral">
	<div class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
		<span class="text-[11px] uppercase tracking-[0.3em] text-[#CCA678] font-bold mb-6 block">EXPORTACIÓN</span>
		<h1 class="text-5xl md:text-6xl font-bold mb-6 font-serif text-[#1A1A1A] leading-tight">El café del Huila para el mundo.</h1>
		<p class="text-[#6B6B6B] text-lg max-w-3xl mb-10 font-light">Relaciones de largo plazo, calidad trazable y un modelo donde el valor regresa a quienes cultivan.</p>
		<a href="/contacto" class="inline-block px-12 py-4 border border-[#1A1A1A]/10 text-[#1A1A1A] text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-[#1A1A1A] hover:text-white transition-all duration-500 rounded-sm">Solicitar información</a>
	</div>
</MainLayout>
